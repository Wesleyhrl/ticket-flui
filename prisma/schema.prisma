// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Chamado{
  id Int @id @default(autoincrement())
  descricao String?
  prioridade Prioridade 
  status Status @default(ABERTO)
  responsavel Usuario @relation(fields: [id_responsavel], references: [id])
  id_responsavel Int
  solicitante_nome String?
  data_abertura DateTime @default(now())
  data_solucao DateTime?
}

model Usuario{
  id Int @id @default(autoincrement())
  nome String
  email String @unique
  senha String
  role Role
  chamados Chamado[]
}

enum Prioridade {
  BAIXA
  MEDIA
  ALTA
}

enum Status {
  ABERTO
  EM_ANDAMENTO
  RESOLVIDO
  FECHADO
}

enum Role {
  ADMIN
  SUPORTE
}
